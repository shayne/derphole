set -euo pipefail

repo_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)
cd "$repo_root"

if ! command -v mise >/dev/null 2>&1; then
  echo "mise is required to run go mod tidy with the repo toolchain." >&2
  echo "Install and run: mise install" >&2
  exit 1
fi

mise exec -- go mod tidy

if ! git diff --exit-code -- go.mod go.sum >/dev/null; then
  echo "" >&2
  echo "go.mod/go.sum changed; please stage the updates and retry the commit." >&2
  exit 1
fi
