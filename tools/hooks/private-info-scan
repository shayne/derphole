set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

if ! command -v mise >/dev/null 2>&1; then
  echo "mise is required to run private-info-scan with the repo toolchain." >&2
  echo "Install and run: mise install" >&2
  exit 1
fi

mise exec -- go run ./tools/privatescan "$repo_root"
